APP_NAME="Biblioteca Virtual API"
APP_VERSION="0.1.0"
ENVIRONMENT="local"  # local | development | staging | production
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/biblioteca"
REDIS_URL="redis://localhost:6379/0"
REDIS_ENABLED=true

# ===== SEGURANÇA =====
SECRET_KEY="me-alterar-em-prod"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== CORS =====
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

LOG_LEVEL="INFO"
RATE_LIMIT_ENABLED=true
CACHE_TTL_SECONDS=60

# NOTIFICAÇÕES
NOTIFICATION_ENABLED=true
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_SCHEDULER_INTERVAL_MINUTES=60

# Quando disparar notificações (dias antes do vencimento)
NOTIFICATION_DAYS_BEFORE=3,1,0
NOTIFICATION_ENABLE_OVERDUE_ALERTS=true

# ===== EMAIL =====

EMAIL_PROVIDER=smtp

# Nome que aparecerá nos emails
EMAIL_SENDER_NAME="Biblioteca Virtual"

# Email que enviará as notificações
EMAIL_SENDER_ADDRESS="noreply@biblioteca-virtual.com"

# === Configuração SMTP (apenas se EMAIL_PROVIDER=smtp) ===

SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USERNAME=1234567890
SMTP_PASSWORD=1234567890
SMTP_USE_TLS=true

# ===== WEBHOOK =====
# Ativar envio de webhooks
WEBHOOK_ENABLED=false

# URL do webhook para receber eventos de notificação
# Seu servidor receberá POST com payload de notificação
WEBHOOK_URL="https://localhost:8080/webhooks/loans"
# Timeout para requisição de webhook (segundos)
WEBHOOK_TIMEOUT=10.0
# Número máximo de tentativas em caso de falha
WEBHOOK_MAX_RETRIES=3

